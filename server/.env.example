# Pick the workshop starting point.
# 1 = brain API, 2 = mentor agent setup, 3 = builder mentor, 4 = paid job flow.
WORKSHOP_STAGE=1
PORT=3001

# Optional live Nebius Token Factory mode.
# Without these values, every AI route returns a labeled fixture response.
# Workshop 2 also uses these values to configure Pi Coding Agent.
NEBIUS_API_KEY=
NEBIUS_MODEL=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
