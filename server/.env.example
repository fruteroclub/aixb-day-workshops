# Pick the workshop starting point.
# 1 = brain API, 2 = mentor agent setup, 3 = builder mentor, 4 = paid job flow.
WORKSHOP_STAGE=1
PORT=3001

# Optional live Nebius Token Factory mode.
# Without these values, every AI route returns a labeled fixture response.
# Workshop 2 also uses these values to configure Pi Coding Agent.
NEBIUS_API_KEY=
NEBIUS_MODEL=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1

# Workshop 4 x402 fixture/testnet metadata.
# The payment gate is toggled from the Workshop 4 UI, not from env.
# X402_MODE=fixture keeps the workshop fully local.
# X402_MODE=base-sepolia uses the official x402 Hono middleware when the UI gate is on.
X402_MODE=fixture
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532
X402_PRICE_USD="$0.001"

# Seller address that receives Base Sepolia x402 payments.
X402_PAY_TO=

# Buyer key used only by npm run x402:pay. Never commit a funded or mainnet key.
X402_BUYER_PRIVATE_KEY=
X402_TEST_BASE_URL=http://localhost:3001

# Workshop 4 ERC-8004 discovery fixture.
PUBLIC_BASE_URL=http://localhost:3001
ERC8004_AGENT_ID=1
ERC8004_AGENT_REGISTRY=eip155:84532:0x0000000000000000000000000000000000008004
